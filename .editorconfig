# EditorConfig: https://editorconfig.org/
# Keeps indentation + line endings consistent across IDEs + platforms.
# Complements .gitattributes (which normalizes the bytes on disk) — this
# file tells your editor which whitespace to write in the first place.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
