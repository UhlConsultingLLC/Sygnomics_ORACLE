# ORACLE environment overrides
# Copy to `.env` and uncomment the lines you want to change.
# .env is gitignored; it never leaves your machine.

# ── Config file path ────────────────────────────────────────────────
# Override the YAML config file location. When set, load_config()
# reads this path instead of config/default_config.yaml.
# CONFIG_PATH=/path/to/custom_config.yaml

# ── Sentry error reporting (optional) ───────────────────────────────
# Set a DSN to enable Sentry error tracking. Leave blank to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Frontend API URL ────────────────────────────────────────────────
# The React app reads this at build/dev time to locate the backend.
# Default: http://localhost:8000
# VITE_API_URL=http://localhost:8000
