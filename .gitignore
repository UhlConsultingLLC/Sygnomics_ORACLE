# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data (TCGA downloads, cached API responses, simulation outputs)
data/tcga_cache/
data/*.h5ad
data/*.csv
data/*.tsv
# Simulation runs produce one hashed directory per user-triggered run,
# containing a summary.json + thousands of per-iteration figures. These
# are runtime artifacts regenerated by the API on demand; they should
# never be committed. Stamps for provenance are baked INTO each file
# when it's generated, so untracking this path does not weaken
# per-artifact traceability.
data/simulations/
!data/.gitkeep

# Database
*.db
*.sqlite
*.sqlite3

# Environment
.env
.env.local

# OS
Thumbs.db
.DS_Store

# Testing
.coverage
htmlcov/
.pytest_cache/

# Node/React frontend
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Temp / scratch
temp_extract/
temp_*.py

# Runtime logs — environment-specific, leak dev-machine paths + timestamps.
*.log

# Build provenance — written by setup.py at pip install time. Contains the
# git SHA + UTC build time for the currently-installed copy. Regenerated on
# every install, never committed.
config/_build_info.py
